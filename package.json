    "postinstall": "node scripts/postinstall.mjs",
    "generate:lighthouse": "node scripts/lighthouse-report.mjs"
  },
  "dependencies": {
    "clsx": "^2.1.0",
    "gray-matter": "^4.0.3",
    "lucide-react": "^0.378.0",
    "next": "^14.2.5",
    "next-mdx-remote": "^5.0.0",
    "next-pwa": "^5.6.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "rehype-autolink-headings": "^7.1.1",
    "rehype-pretty-code": "^2.0.5",
    "rehype-slug": "^6.0.1",
    "remark-gfm": "^3.0.1",
    "shiki": "^1.6.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@playwright/test": "^1.45.1",
